# Supabase Configuration
# Copy this file to .env and fill in your values
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=

# Cloudinary Configuration
# Get these from: https://cloudinary.com/console → Dashboard (top-left)
# ⚠️  Only Cloud Name + Upload Preset are needed here — never put API Secret in VITE_ vars!
VITE_CLOUDINARY_CLOUD_NAME=dorxkrf4i
VITE_CLOUDINARY_UPLOAD_PRESET=live in marrakech
